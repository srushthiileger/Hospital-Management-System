  },
  "item": [
    {
      "name": "Create Patient",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\":\"Rahul\",\n  \"age\":25,\n  \"Gender\":\"Male\",\n  \"phone\":\"9876543210\",\n  \"Adress\":\"Belagavi\",\n  \"DOF\":\"2026-07-07\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/hospital",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "hospital"
          ]
        }
      }
    },
    {
